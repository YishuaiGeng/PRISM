\@writefile{toc}{\contentsline {subsection}{\numberline {3.2}PRISM总体框架}{6}{subsection.3.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces PRISM的离线范式提炼与在线修复记忆框架。\textbf  {离线}（上行）：成功求解轨迹经 KDP 识别、跨轨迹聚类、LLM 抽象和 Z3三重筛选，提炼为可复用范式库（约 40:1 压缩比）。\textbf  {在线}（下行）：新谜题的推断步骤由范式引导并经 Z3验证；若返回 \textsc  {Unsat}，系统提取 UNSAT core 进行归因，记录至类型化修复记忆，并在检测到停滞或循环时触发 L1–L4 策略切换。}}{7}{figure.1}\protected@file@percent }
\newlabel{fig:framework}{{1}{7}{\PRISM 的离线范式提炼与在线修复记忆框架。\textbf {离线}（上行）：成功求解轨迹经 KDP 识别、跨轨迹聚类、LLM 抽象和 \zthree 三重筛选，提炼为可复用范式库（约 40:1 压缩比）。\textbf {在线}（下行）：新谜题的推断步骤由范式引导并经 \zthree 验证；若返回 \unsat ，系统提取 UNSAT core 进行归因，记录至类型化修复记忆，并在检测到停滞或循环时触发 L1–L4 策略切换。}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces 范式表示（左）与修复轨迹记录（右）的具体示例。范式携带可被 Z3机械检验的前后条件；修复记录通过 UNSAT core 指纹检测停滞并指导策略切换。}}{7}{figure.2}\protected@file@percent }
\newlabel{fig:example}{{2}{7}{范式表示（左）与修复轨迹记录（右）的具体示例。范式携带可被 \zthree 机械检验的前后条件；修复记录通过 UNSAT core 指纹检测停滞并指导策略切换。}{figure.2}{}}
